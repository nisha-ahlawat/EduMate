# Copy to .env and fill in values. Never commit .env.

# MongoDB connection string (Atlas or local)
# Example Atlas: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/edumate?retryWrites=true&w=majority
# Example local: mongodb://127.0.0.1:27017/edumate
MONGODB_URI=

# JWT signing secrets (use long random strings in production)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Server
PORT=5000

# Allowed browser origin for cookies/CORS (no trailing slash)
FRONTEND_API_LINK=http://localhost:3000

# Optional: set to production in deployed environments
# NODE_ENV=development
